module users

schema User {
  id: UserId
  email: Email
  name: NonEmptyString
  status: UserStatus
}

enum UserStatus {
  Pending
  Active
  Suspended
}

command RegisterUser {
  email: Email
  name: NonEmptyString
}

event UserRegistered {
  userId: UserId
  at: Instant
}

query GetUserProfile {
  input: UserId
  output: User
}
